# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ───────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ────────────────────────────────────────────────────────────────────
/.next/
/out/

# ─── Production Build ────────────────────────────────────────────────────────────
/build
/dist

# ─── Testing ─────────────────────────────────────────────────────────────────────
/coverage
.nyc_output

# ─── Environment Variables ───────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Debug Logs ──────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── TypeScript ──────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Vercel ──────────────────────────────────────────────────────────────────────
.vercel

# ─── OS Artifacts ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.pem

# ─── Editor / IDE ────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ─── Markdown (non-essential) ────────────────────────────────────────────────────
AGENTS.md
CLAUDE.md
COPILOT.md
GEMINI.md

# ─── Misc ────────────────────────────────────────────────────────────────────────
*.tgz
.cache
